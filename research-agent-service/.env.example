# Все переменные — с префиксом RESEARCH_AGENT_ (pydantic-settings).
# Набор растёт по мере появления адаптеров; здесь — базовая часть.

# --- Идентификация сервиса ---
RESEARCH_AGENT_SERVICE_NAME=research-agent-service
RESEARCH_AGENT_LOG_LEVEL=INFO

# --- PostgreSQL (история диалогов, agent_runs, tool_calls, feedback, outbox) ---
RESEARCH_AGENT_DATABASE_URL=postgresql+asyncpg://research_agent:research_agent@localhost:5432/research_agent

# --- Redis (кеш, rate limiting, идемпотентность) ---
RESEARCH_AGENT_REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ (публикация событий через outbox-relay) ---
RESEARCH_AGENT_RABBITMQ_DSN=amqp://guest:guest@localhost:5672/

# --- LLM (OpenAI-совместимый эндпоинт с кастомным base_url) ---
RESEARCH_AGENT_LLM__BASE_URL=http://localhost:8001/v1
RESEARCH_AGENT_LLM__MODEL=qwen3
RESEARCH_AGENT_LLM__API_KEY=sk-local
RESEARCH_AGENT_LLM__TEMPERATURE=0.0
RESEARCH_AGENT_LLM__MAX_TOKENS=4096
RESEARCH_AGENT_LLM__SERVICE_TIER=auto
RESEARCH_AGENT_LLM__ENABLE_THINKING=false

# --- Наблюдаемость: distributed tracing (опционально) ---
# Пусто = трейсинг выключен. Задайте OTLP/HTTP endpoint, чтобы включить.
# RESEARCH_AGENT_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
