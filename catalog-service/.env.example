# Скопируйте в .env и при необходимости отредактируйте.
# --- PostgreSQL ---
CATALOG_DATABASE_URL=postgresql+asyncpg://catalog:catalog@localhost:5432/catalog
CATALOG_SQL_ECHO=false
# --- RabbitMQ ---
CATALOG_RABBITMQ_DSN=amqp://guest:guest@localhost:5672/
# --- Домен ---
CATALOG_DEFAULT_CURRENCY=RUB
# --- Outbox relay ---
CATALOG_OUTBOX_POLL_INTERVAL_S=1.0
CATALOG_OUTBOX_BATCH_SIZE=100
CATALOG_OUTBOX_MAX_ATTEMPTS=10
# --- Наблюдаемость ---
CATALOG_LOG_LEVEL=INFO
