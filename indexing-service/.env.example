# --- Брокер (источник событий каталога) ---
INDEXING_RABBITMQ_DSN=amqp://guest:guest@localhost:5672/

# --- Qdrant (поисковая read-model) ---
INDEXING_QDRANT_URL=http://localhost:6333
INDEXING_QDRANT_API_KEY=
INDEXING_COLLECTION_ALIAS=products

# --- catalog-service (repair / reindex / reconcile) ---
INDEXING_CATALOG_BASE_URL=http://localhost:8000

# --- Домен ---
INDEXING_DEFAULT_CURRENCY=RUB

# --- Эмбеддер (BGE-M3) ---
# local — in-process FlagEmbedding; remote — внешний сервис (TEI/Infinity); fake — тесты.
INDEXING_EMBEDDING_MODE=local
INDEXING_EMBEDDING_MODEL=BAAI/bge-m3
INDEXING_EMBEDDING_REVISION=
INDEXING_EMBEDDING_DEVICE=cpu

# --- Источник данных на горячем пути: event | hybrid | fetch ---
INDEXING_SOURCE_MODE=hybrid

# --- Консюмер: QoS и retry/DLQ ---
INDEXING_PREFETCH_COUNT=32
INDEXING_MAX_ATTEMPTS=5
INDEXING_RETRY_TTL_MS=30000
