# --- Брокер (источник событий каталога) ---
INDEXING_RABBITMQ_DSN=amqp://guest:guest@localhost:5672/

# --- PostgreSQL (indexing jobs + transactional outbox) ---
INDEXING_DATABASE_URL=postgresql+asyncpg://indexing:indexing@localhost:5432/indexing

# --- Qdrant (поисковая read-model) ---
INDEXING_QDRANT_URL=http://localhost:6333
INDEXING_QDRANT_API_KEY=
INDEXING_COLLECTION_ALIAS=products

# --- catalog-service (repair / reindex / reconcile) ---
INDEXING_CATALOG_BASE_URL=http://localhost:8000

# --- Домен ---
INDEXING_DEFAULT_CURRENCY=RUB

# --- Эмбеддинги (считает embedding-service, мы только заказываем) ---
# Размерность векторов; должна совпадать с моделью embedding-service.
INDEXING_EMBEDDING_DIM=1024
# Пусто = доверяем текущей модели embedding-service, дрейф ловит reconcile.
INDEXING_EXPECTED_MODEL=
# Операционный лимит батча embedding-service: длиннее команду не шлём.
INDEXING_MAX_TEXTS=32

# --- Источник данных на горячем пути: event | hybrid | fetch ---
INDEXING_SOURCE_MODE=hybrid

# --- Консюмер: QoS и retry/DLQ ---
INDEXING_PREFETCH_COUNT=32
INDEXING_MAX_ATTEMPTS=5
INDEXING_RETRY_TTL_MS=30000

# --- Outbox-relay (публикация команд в embedding.jobs) ---
INDEXING_OUTBOX_POLL_INTERVAL_S=1.0
INDEXING_OUTBOX_MAX_ATTEMPTS=10
INDEXING_OUTBOX_BATCH_SIZE=100

# --- Ретраи чанка при INFERENCE_FAILED ---
INDEXING_MAX_ITEM_ATTEMPTS=5
INDEXING_ITEM_RETRY_BACKOFF_S=5.0
INDEXING_ITEM_RETRY_BACKOFF_CAP_S=300.0

# --- Наблюдаемость: distributed tracing (опционально) ---
# Пусто = трейсинг выключен. Задайте OTLP/HTTP endpoint, чтобы включить.
# INDEXING_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

