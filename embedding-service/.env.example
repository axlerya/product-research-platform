# --- Транспорты ---
EMBEDDING_RABBITMQ_DSN=amqp://guest:guest@localhost:5672/
EMBEDDING_GRPC_HOST=0.0.0.0
EMBEDDING_GRPC_PORT=50051
EMBEDDING_OPS_HOST=0.0.0.0
EMBEDDING_OPS_HTTP_PORT=8000

# --- Провайдер эмбеддингов ---
# bge_m3 — реальная модель (extra "embedding"); deterministic — FAKE для CI/smoke.
EMBEDDING_PROVIDER_MODE=bge_m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_REVISION=
EMBEDDING_DIM=1024
EMBEDDING_POOLING=cls
EMBEDDING_NORMALIZED=true

# --- Устройство и точность ---
# device: auto (cuda→cpu) | cpu | cuda; precision: fp32 | fp16 | bf16.
EMBEDDING_DEVICE=auto
EMBEDDING_PRECISION=fp16
EMBEDDING_CPU_FALLBACK=false

# --- Батчинг и конкурентность ---
EMBEDDING_MAX_BATCH_SIZE=16
EMBEDDING_BATCH_WAIT_MS=50
EMBEDDING_QUERY_BATCH_WAIT_MS=5
EMBEDDING_MAX_CONCURRENT_INFERENCES=1
EMBEDDING_MAX_QUEUE_SIZE=256
EMBEDDING_INFERENCE_TIMEOUT_S=30
EMBEDDING_PREFETCH_COUNT=8

# --- Лимиты запроса (документы/запросы конфигурируются раздельно) ---
EMBEDDING_DOC_MAX_TEXTS=256
EMBEDDING_DOC_MAX_TEXT_CHARS=32000
EMBEDDING_DOC_MAX_TOKENS=8192
EMBEDDING_DOC_MAX_TOTAL_BYTES=4194304
EMBEDDING_QUERY_MAX_TEXTS=32
EMBEDDING_QUERY_MAX_TEXT_CHARS=8000
EMBEDDING_QUERY_MAX_TOKENS=8192
EMBEDDING_QUERY_MAX_TOTAL_BYTES=262144

# --- Консюмер: retry/DLQ ---
EMBEDDING_MAX_ATTEMPTS=5
EMBEDDING_RETRY_TTL_MS=30000
EMBEDDING_GRACEFUL_TIMEOUT=30

# --- Наблюдаемость (distributed tracing, опционально) ---
# Пусто = трейсинг выключен. Задайте OTLP/HTTP endpoint, чтобы включить.
# EMBEDDING_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
EMBEDDING_SERVICE_NAME=embedding-service

# --- Reranker (BAAI/bge-reranker-v2-m3, ОПЦИОНАЛЬНО, префикс RERANKER_) ---
# Полностью изолирован от BGE-M3. По умолчанию выключен — сервис стартует в
# прежнем режиме. Сбой загрузки reranker не влияет на embeddings.
RERANKER_ENABLED=false
# bge_reranker — реальная модель (extra "reranking"); deterministic — FAKE.
RERANKER_PROVIDER_MODE=bge_reranker
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_REVISION=
RERANKER_NORMALIZED=true
RERANKER_DEVICE=auto
RERANKER_PRECISION=fp16
RERANKER_MAX_BATCH_SIZE=32
RERANKER_INFERENCE_TIMEOUT_S=10
RERANKER_MAX_CONCURRENT_INFERENCES=1
RERANKER_MAX_DOCUMENTS=256
RERANKER_MAX_QUERY_CHARS=8000
RERANKER_MAX_DOCUMENT_CHARS=32000
RERANKER_MAX_TOTAL_BYTES=4194304
